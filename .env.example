# ── sk-mind 环境配置 ────────────────────────
# 复制此文件为 .env 并根据实际环境修改

# 应用
SKMIND_APP_NAME=sk-mind
SKMIND_APP_VERSION=0.1.0
SKMIND_DEBUG=false
SKMIND_LOG_LEVEL=INFO

# 数据库
SKMIND_DATABASE_URL=postgresql+asyncpg://skmind:skmind@localhost:5432/skmind
SKMIND_DATABASE_URL_SYNC=postgresql+psycopg2://skmind:skmind@localhost:5432/skmind

# Redis
SKMIND_REDIS_URL=redis://localhost:6379/0

# JWT
SKMIND_SECRET_KEY=change-me-in-production-use-a-random-string
SKMIND_ALGORITHM=HS256
SKMIND_ACCESS_TOKEN_EXPIRE_MINUTES=480

# 文件
SKMIND_DATA_DIR=/data
SKMIND_UPLOAD_DIR=/data/uploads
SKMIND_MAX_UPLOAD_SIZE_MB=100

# LLM（默认关闭）
SKMIND_LLM_PROVIDER=disabled
SKMIND_LLM_API_KEY=
SKMIND_LLM_BASE_URL=

# CORS
SKMIND_CORS_ORIGINS=["http://localhost:5173","http://localhost:80"]
